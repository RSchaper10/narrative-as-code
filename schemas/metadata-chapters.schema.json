{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narrative Chapter Metadata",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "order",
      "slug",
      "title",
      "pov",
      "status",
      "summary"
    ],
    "properties": {
      "order": {
        "type": "integer",
        "minimum": 0
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "pov": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "minLength": 1
      },
      "summary": {
        "type": "string",
        "minLength": 1
      }
    },
    "additionalProperties": true
  }
}
