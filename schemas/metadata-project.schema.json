{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narrative Project Metadata",
  "type": "object",
  "required": [
    "title",
    "slug",
    "subtitle",
    "status",
    "draft_label",
    "target_word_count",
    "primary_build_outputs",
    "source_of_truth"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "subtitle": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "draft_label": {
      "type": "string",
      "minLength": 1
    },
    "target_word_count": {
      "type": "integer",
      "minimum": 1
    },
    "primary_build_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_of_truth": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
